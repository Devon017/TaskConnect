                description: "Need technician to install Microsoft Office and antivirus on 5 desktop computers in our office.",
                category: "Computer Repair",
                budget: "KSh 2,500 - 4,000",
                deadline: "Tomorrow",
                location: "Upper Hill",
                postedBy: "Admin O.",
                avatar: "https://i.pravatar.cc/150?img=12",
                proposals: 4,
                featured: false,
                coordinates: { lat: -1.3000, lng: 36.8167 }
            }
        ];

        const MOCK_FREELANCERS = [
            {
                id: 1,
                name: "David Kimani",
                skills: ["Graphic Design", "Branding", "Photoshop"],
                rating: 4.9,
                completed: 47,
                hourlyRate: "KSh 1,500",
                avatar: "https://i.pravatar.cc/150?img=11",
                verified: true,
                location: "Nairobi"
            },
            {
                id: 2,
                name: "Mary Ochieng",
                skills: ["Computer Repair", "Networking", "IT Support"],
                rating: 4.8,
                completed: 32,
                hourlyRate: "KSh 1,000",
                avatar: "https://i.pravatar.cc/150?img=16",
                verified: true,
                location: "Westlands"
            },
            {
                id: 3,
                name: "James Mwangi",
                skills: ["Academic Writing", "Research", "Data Analysis"],
                rating: 4.7,
                completed: 28,
                hourlyRate: "KSh 800",
                avatar: "https://i.pravatar.cc/150?img=13",
                verified: false,
                location: "Remote"
            }
        ];

        const MOCK_MESSAGES = [
            {
                id: 1,
                sender: "Grace M.",
                avatar: "https://i.pravatar.cc/150?img=1",
                lastMessage: "Can you make the poster blue instead?",
                time: "2m ago",
