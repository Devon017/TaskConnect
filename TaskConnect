                                    </div>
                                    <span className="text-green-600 text-sm font-medium flex items-center gap-1">
                                        <CheckCircle className="w-4 h-4" /> Verified
                                    </span>
                                </button>
                            </div>

                            <div className="bg-white rounded-2xl shadow-sm overflow-hidden">
                                <button className="w-full px-4 py-4 flex items-center justify-between hover:bg-gray-50 text-red-600">
                                    <div className="flex items-center gap-3">
                                        <div className="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                            <X className="w-5 h-5 text-red-600" />
                                        </div>
                                        <span className="font-medium">Log Out</span>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                );
            };

            // Bid Screen
            const BidScreen = () => {
                const [bidAmount, setBidAmount] = useState('');
                const [proposal, setProposal] = useState('');

                return (
                    <div className="min-h-screen bg-gray-50">
                        <div className="bg-white px-4 pt-12 pb-4 shadow-sm sticky top-0 z-10">
                            <button 
                                onClick={() => setCurrentView('taskDetail')}
                                className="flex items-center gap-2 text-gray-600"
                            >
                                <ChevronRight className="w-5 h-5 rotate-180" /> Back
                            </button>
                            <h1 className="text-xl font-bold mt-2">Submit Proposal</h1>
                        </div>

                        <div className="p-4 space-y-4">
                            <div className="bg-white p-4 rounded-2xl shadow-sm">
                                <h3 className="font-semibold mb-2">{selectedTask?.title}</h3>
                                <p className="text-sm text-gray-600 mb-3">{selectedTask?.description}</p>
                                <div className="flex items-center gap-4 text-sm text-gray-600">
                                    <span className="flex items-center gap-1">
                                        <DollarSign className="w-4 h-4" /> Budget: {selectedTask?.budget}
                                    </span>
                                </div>
                            </div>

                            <div className="bg-white p-4 rounded-2xl shadow-sm space-y-4">
                                <div>
                                    <label className="block text-sm font-medium text-gray-700 mb-2">Your Bid (KSh)</label>
                                    <div className="relative">
                                        <span className="absolute left-3 top-3 text-gray-500 font-semibold">KSh</span>
                                        <input 
                                            type="number" 
                                            className="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-lg font-semibold"
                                            placeholder="Enter amount"
                                            value={bidAmount}
                                            onChange={(e) => setBidAmount(e.target.value)}
                                        />
                                    </div>
                                    <p className="text-xs text-gray-500 mt-1">Platform fee (10%): KSh {bidAmount ? Math.round(bidAmount * 0.1) : 0}</p>
                                </div>

                                <div>
                                    <label className="block text-sm font-medium text-gray-700 mb-2">Cover Letter</label>
                                    <textarea 
                                        className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none resize-none"
                                        rows={5}
                                        placeholder="Explain why you're perfect for this task..."
                                        value={proposal}
                                        onChange={(e) => setProposal(e.target.value)}
                                    />
                                </div>

                                <div className="bg-indigo-50 p-3 rounded-lg flex items-start gap-2">
                                    <Sparkles className="w-5 h-5 text-indigo-600 mt-0.5" />
                                    <div>
                                        <p className="text-sm font-medium text-indigo-900">AI Proposal Helper</p>
                                        <p className="text-xs text-indigo-700 mt-1">Highlight your experience with {selectedTask?.category} to increase your chances.</p>
                                    </div>
                                </div>
                            </div>

                            <Button onClick={() => {
                                showNotification("Proposal submitted successfully!");
                                setCurrentView('home');
                            }}>
                                Submit Proposal
                            </Button>
                        </div>
                    </div>
                );
            };

            // Payment Modal
            const PaymentModal = () => (
                <div className="fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-4">
                    <div className="bg-white w-full max-w-md rounded-3xl p-6 slide-in">
                        <div className="flex justify-between items-center mb-6">
                            <h2 className="text-xl font-bold">Payment</h2>
                            <button onClick={() => setShowPaymentModal(false)} className="p-2 hover:bg-gray-100 rounded-full">
                                <X className="w-6 h-6" />
                            </button>
                        </div>
                        
                        <div className="text-center mb-6">
                            <div className="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                <CreditCard className="w-8 h-8 text-green-600" />
                            </div>
                            <h3 className="font-semibold text-lg">Pay with M-Pesa</h3>
                            <p className="text-gray-600 text-sm">Enter your M-Pesa number to complete payment</p>
                        </div>

                        <Input 
                            label="M-Pesa Number" 
                            placeholder="07XX XXX XXX"
                            icon={Phone}
                        />

                        <div className="bg-gray-50 p-4 rounded-xl mb-6">
                            <div className="flex justify-between mb-2">
                                <span className="text-gray-600">Task Amount</span>
                                <span className="font-semibold">KSh 5,000</span>
                            </div>
                            <div className="flex justify-between mb-2">
                                <span className="text-gray-600">Service Fee (5%)</span>
                                <span className="font-semibold">KSh 250</span>
                            </div>
                            <div className="border-t border-gray-200 pt-2 flex justify-between">
                                <span className="font-semibold">Total</span>
                                <span className="font-bold text-indigo-600">KSh 5,250</span>
                            </div>
                        </div>

                        <Button onClick={() => {
                            setShowPaymentModal(false);
                            showNotification("Payment initiated! Check your phone.");
                        }}>
                            Pay Now
                        </Button>
                    </div>
                </div>
            );

            // Notification Toast
            const NotificationToast = () => {
                if (!notification) return null;
                return (
                    <div className="fixed top-20 left-4 right-4 bg-gray-900 text-white px-4 py-3 rounded-xl shadow-2xl z-50 flex items-center gap-3 fade-in">
                        <CheckCircle className="w-5 h-5 text-green-400" />
                        <span className="font-medium">{notification.message}</span>
                    </div>
                );
            };

            // Render current view
            const renderView = () => {
                switch(currentView) {
                    case 'welcome': return <WelcomeScreen />;
                    case 'register': return <RegisterScreen />;
                    case 'login': return <RegisterScreen />;
                    case 'home': return <HomeScreen />;
                    case 'taskDetail': return <TaskDetailScreen />;
                    case 'postTask': return <PostTaskScreen />;
                    case 'messages': return <MessagesScreen />;
                    case 'chat': return <ChatScreen />;
                    case 'profile': return <ProfileScreen />;
                    case 'bid': return <BidScreen />;
                    default: return <WelcomeScreen />;
                }
            };

            return (
                <div className="max-w-md mx-auto bg-white min-h-screen shadow-2xl overflow-hidden relative">
                    {renderView()}
                    {showPaymentModal && <PaymentModal />}
                    <NotificationToast />
                </div>
            );
        };

        // Render the app
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<TaskConnectApp />);
    </script>
</body>
</html>
