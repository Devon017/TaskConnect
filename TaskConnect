                                            <span className="font-medium">{item.title}</span>
                                        </div>
                                        {item.badge ? (
                                            <span className="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-xs font-bold">{item.badge}</span>
                                        ) : item.status ? (
                                            <span className="text-green-600 text-sm font-medium flex items-center gap-1">
                                                <Icon path={Icons.check} className="w-4 h-4" /> {item.status}
                                            </span>
                                        ) : (
                                            <Icon path={Icons.chevronRight} className="w-5 h-5 text-gray-400" />
                                        )}
                                    </button>
                                ))}
                            </div>

                            <button 
                                onClick={() => setCurrentView('welcome')}
                                className="w-full py-3 px-4 bg-red-50 text-red-600 rounded-xl font-semibold flex items-center justify-center gap-2"
                            >
                                <Icon path={Icons.x} className="w-5 h-5" /> Log Out
                            </button>
                        </div>
                    </div>
                );
            }

            // Bid Screen
            if (currentView === 'bid') {
                return (
                    <div className="min-h-screen bg-gray-50">
                        <div className="bg-white px-4 pt-12 pb-4 shadow-sm sticky top-0 z-10">
                            <button 
                                onClick={() => setCurrentView('taskDetail')}
                                className="flex items-center gap-2 text-gray-600"
                            >
                                <Icon path={Icons.chevronRight} className="w-5 h-5 rotate-180" /> Back
                            </button>
                            <h1 className="text-xl font-bold mt-2">Submit Proposal</h1>
                        </div>

                        <div className="p-4 space-y-4">
                            <div className="bg-white p-4 rounded-2xl shadow-sm">
                                <h3 className="font-semibold mb-2">{selectedTask?.title}</h3>
                                <p className="text-sm text-gray-600 mb-3">{selectedTask?.description}</p>
                                <div className="flex items-center gap-4 text-sm text-gray-600">
                                    <span className="flex items-center gap-1">
                                        <Icon path={Icons.dollar} className="w-4 h-4" /> Budget: {selectedTask?.budget}
                                    </span>
                                </div>
                            </div>

                            <div className="bg-white p-4 rounded-2xl shadow-sm space-y-4">
                                <div>
                                    <label className="block text-sm font-medium text-gray-700 mb-2">Your Bid (KSh)</label>
                                    <div className="relative">
                                        <span className="absolute left-3 top-3 text-gray-500 font-semibold">KSh</span>
                                        <input 
                                            type="number" 
                                            className="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-lg font-semibold"
                                            placeholder="Enter amount"
                                        />
                                    </div>
                                    <p className="text-xs text-gray-500 mt-1">Platform fee (10%): KSh 0</p>
                                </div>

                                <div>
                                    <label className="block text-sm font-medium text-gray-700 mb-2">Cover Letter</label>
                                    <textarea 
                                        className="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none resize-none"
                                        rows={5}
                                        placeholder="Explain why you're perfect for this task..."
                                    />
                                </div>

                                <div className="bg-indigo-50 p-3 rounded-lg flex items-start gap-2">
                                    <Icon path={Icons.sparkles} className="w-5 h-5 text-indigo-600 mt-0.5" />
                                    <div>
                                        <p className="text-sm font-medium text-indigo-900">AI Proposal Helper</p>
                                        <p className="text-xs text-indigo-700 mt-1">Highlight your experience with {selectedTask?.category} to increase your chances.</p>
                                    </div>
                                </div>
                            </div>

                            <button 
                                onClick={() => { showNotification("Proposal submitted!"); setCurrentView('home'); }}
                                className="w-full py-3 px-4 bg-indigo-600 text-white rounded-xl font-semibold shadow-lg shadow-indigo-200"
                            >
                                Submit Proposal
                            </button>
                        </div>
                    </div>
                );
            }

            // Notification Toast
            if (notification) {
                return (
                    <div className="fixed top-20 left-4 right-4 bg-gray-900 text-white px-4 py-3 rounded-xl shadow-2xl z-50 flex items-center gap-3 fade-in max-w-md mx-auto">
                        <Icon path={Icons.check} className="w-5 h-5 text-green-400" />
                        <span className="font-medium">{notification}</span>
                    </div>
                );
            }

            return null;
        };

        // Mount the app
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<TaskConnectApp />);
    </script>
</body>
</html>
