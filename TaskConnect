                                                        {skill}
                                                    </button>
                                                ))}
                                            </div>
                                        </div>
                                    )}

                                    <Input 
                                        label="Location" 
                                        placeholder="e.g., Nairobi, Westlands"
                                        icon={MapPin}
                                    />

                                    <div className="flex gap-3 mt-6">
                                        <Button variant="secondary" onClick={() => setStep(2)} className="flex-1">Back</Button>
                                        <Button onClick={handleRegister} className="flex-1">Complete</Button>
                                    </div>
                                </div>
                            )}
