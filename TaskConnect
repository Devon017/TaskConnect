                                    </div>

                                    {role !== 'client' && (
                                        <div className="mb-4">
                                            <label className="block text-sm font-medium text-gray-700 mb-2">Your Skills (select up to 5)</label>
                                            <div className="flex flex-wrap gap-2">
                                                {['Graphic Design', 'Writing', 'Programming', 'Repair', 'Photography', 'Tutoring'].map(skill => (
                                                    <button 
                                                        key={skill}
