                                        React.createElement('path', { key: 'p2', fill: "#34A853", d: "M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" }),
                                        React.createElement('path', { key: 'p3', fill: "#FBBC05", d: "M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" }),
                                        React.createElement('path', { key: 'p4', fill: "#EA4335", d: "M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" })
                                    ]),
                                    "Continue with Google"
                                ])
                            ])
                        ]),

                        // Footer
                        React.createElement('p', {
                            key: 'footer',
                            className: "text-center mt-6 text-gray-600"
                        }, [
                            "Don't have an account? ",
                            React.createElement('button', {
                                key: 'link',
                                onClick: () => setCurrentScreen('register'),
                                className: "text-indigo-600 font-bold hover:text-indigo-700"
                            }, "Sign up")
                        ])
                    ])
                ]);
            }

            // Register Screen
            if (currentScreen === 'register') {
                const [step, setStep] = useState(1);
                const [selectedRole, setSelectedRole] = useState(null);

                const roles = [
                    { id: 'client', title: 'Hire Freelancers', desc: 'Post tasks and get work done', icon: Icons.briefcase, color: 'from-blue-500 to-indigo-600' },
                    { id: 'freelancer', title: 'Work as Freelancer', desc: 'Find tasks and earn money', icon: Icons.user, color: 'from-green-500 to-teal-600' },
                    { id: 'both', title: 'Both', desc: 'Hire and work flexibly', icon: Icons.star, color: 'from-purple-500 to-pink-600' }
                ];

                return React.createElement('div', { className: "min-h-screen bg-white" }, [
                    // Header
                    React.createElement('div', {
                        key: 'header',
                        className: "bg-gradient-to-br from-indigo-600 to-purple-700 px-6 pt-12 pb-16"
                    }, [
                        React.createElement('button', {
                            key: 'back',
                            onClick: () => step === 1 ? setCurrentScreen('welcome') : setStep(step - 1),
                            className: "mb-6 text-white/80 flex items-center gap-2 hover:text-white transition-colors"
                        }, [
                            React.createElement(Icon, { key: 'icon', path: Icons.chevronRight, className: "w-5 h-5 rotate-180" }),
                            step === 1 ? 'Back' : 'Previous'
                        ]),

                        // Progress
                        React.createElement('div', {
                            key: 'progress',
                            className: "flex items-center gap-2 mb-4"
                        }, [1, 2, 3].map(i => 
                            React.createElement('div', {
                                key: i,
                                className: `h-1.5 rounded-full transition-all duration-300 ${i <= step ? 'w-8 bg-white' : 'w-4 bg-white/30'}`
                            })
                        )),

                        React.createElement('h1', {
                            key: 'title',
                            className: "text-3xl font-bold text-white mb-2"
                        }, step === 1 ? 'Choose Your Path' : step === 2 ? 'Create Account' : 'Complete Profile'),

                        React.createElement('p', {
                            key: 'subtitle',
                            className: "text-indigo-100"
                        }, `Step ${step} of 3`)
                    ]),

                    // Content
                    React.createElement('div', {
                        key: 'content',
                        className: "px-6 -mt-8 relative z-10"
                    }, [
                        React.createElement('div', {
                            key: 'card',
                            className: "bg-white rounded-3xl shadow-xl p-6"
                        }, [
                            // Step 1: Role Selection
                            step === 1 && React.createElement('div', {
                                key: 'step1',
                                className: "space-y-4"
                            }, [
                                roles.map((role, idx) => 
                                    React.createElement('button', {
                                        key: role.id,
                                        onClick: () => setSelectedRole(role.id),
                                        className: `w-full p-5 rounded-2xl border-2 transition-all duration-200 text-left ${
                                            selectedRole === role.id 
                                                ? 'border-indigo-600 bg-indigo-50 shadow-md' 
                                                : 'border-gray-100 hover:border-gray-200 hover:bg-gray-50'
                                        }`
                                    }, [
                                        React.createElement('div', {
                                            key: 'content',
                                            className: "flex items-center gap-4"
                                        }, [
                                            React.createElement('div', {
                                                key: 'icon',
                                                className: `w-14 h-14 bg-gradient-to-br ${role.color} rounded-2xl flex items-center justify-center shadow-lg`
                                            }, React.createElement(Icon, { path: role.icon, className: "w-7 h-7 text-white" })),
                                            React.createElement('div', { key: 'text' }, [
                                                React.createElement('h3', {
                                                    key: 'title',
                                                    className: `font-bold text-lg ${selectedRole === role.id ? 'text-indigo-900' : 'text-gray-900'}`
                                                }, role.title),
                                                React.createElement('p', {
                                                    key: 'desc',
                                                    className: "text-gray-500 text-sm"
                                                }, role.desc)
                                            ]),
                                            selectedRole === role.id && React.createElement('div', {
                                                key: 'check',
                                                className: "ml-auto w-6 h-6 bg-indigo-600 rounded-full flex items-center justify-center"
                                            }, React.createElement(Icon, { path: Icons.check, className: "w-4 h-4 text-white" }))
                                        ])
                                    ])
                                ),

                                React.createElement('button', {
                                    key: 'continue',
                                    disabled: !selectedRole,
                                    onClick: () => setStep(2),
                                    className: "w-full py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-bold text-lg shadow-lg shadow-indigo-200 disabled:opacity-50 disabled:cursor-not-allowed hover:shadow-xl transition-all mt-4"
                                }, "Continue")
                            ]),

                            // Step 2: Account Details
                            step === 2 && React.createElement('div', {
                                key: 'step2',
                                className: "space-y-4"
                            }, [
                                ['Full Name', 'Email Address', 'Phone Number', 'Password'].map((label, idx) => 
                                    React.createElement('div', { key: label }, [
                                        React.createElement('label', {
                                            className: "block text-sm font-medium text-gray-700 mb-2"
                                        }, label),
                                        React.createElement('input', {
                                            type: label === 'Password' ? 'password' : label === 'Email Address' ? 'email' : 'text',
                                            placeholder: label === 'Phone Number' ? '7XX XXX XXX' : label === 'Full Name' ? 'John Doe' : `Enter ${label.toLowerCase()}`,
                                            className: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                                        })
                                    ])
                                ),

                                React.createElement('div', {
                                    key: 'buttons',
                                    className: "flex gap-3 mt-6"
                                }, [
                                    React.createElement('button', {
                                        key: 'back',
                                        onClick: () => setStep(1),
                                        className: "flex-1 py-4 border-2 border-gray-200 text-gray-700 rounded-xl font-bold hover:bg-gray-50 transition-colors"
                                    }, "Back"),
                                    React.createElement('button', {
                                        key: 'next',
                                        onClick: () => setStep(3),
                                        className: "flex-1 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-bold shadow-lg hover:shadow-xl transition-all"
                                    }, "Next")
                                ])
                            ]),

                            // Step 3: Profile
                            step === 3 && React.createElement('div', {
                                key: 'step3',
                                className: "space-y-4"
                            }, [
                                // Photo Upload
                                React.createElement('div', {
                                    key: 'photo',
                                    className: "text-center mb-6"
                                }, [
                                    React.createElement('div', {
                                        className: "w-28 h-28 bg-gradient-to-br from-gray-100 to-gray-200 rounded-full mx-auto mb-4 flex items-center justify-center border-4 border-dashed border-gray-300 relative overflow-hidden group cursor-pointer"
                                    }, [
                                        React.createElement(Icon, {
                                            path: Icons.camera,
                                            className: "w-10 h-10 text-gray-400 group-hover:text-indigo-500 transition-colors"
                                        }),
                                        React.createElement('div', {
                                            className: "absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors"
                                        })
                                    ]),
                                    React.createElement('p', {
                                        className: "text-gray-600 font-medium"
                                    }, "Add Profile Photo"),
                                    React.createElement('p', {
                                        className: "text-gray-400 text-sm"
                                    }, "Optional, but recommended")
                                ]),

                                // Location
                                React.createElement('div', { key: 'location' }, [
                                    React.createElement('label', {
                                        className: "block text-sm font-medium text-gray-700 mb-2"
                                    }, "Location"),
                                    React.createElement('div', { className: "relative" }, [
                                        React.createElement(Icon, {
                                            path: Icons.mapPin,
                                            className: "absolute left-4 top-3.5 w-5 h-5 text-gray-400"
                                        }),
                                        React.createElement('input', {
                                            type: "text",
                                            placeholder: "e.g., Nairobi, Westlands",
                                            className: "w-full pl-12 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                                        })
                                    ])
                                ]),

                                // Skills
                                React.createElement('div', { key: 'skills' }, [
                                    React.createElement('label', {
                                        className: "block text-sm font-medium text-gray-700 mb-2"
                                    }, "Skills (if freelancer)"),
                                    React.createElement('div', {
                                        className: "flex flex-wrap gap-2"
                                    }, ['Design', 'Writing', 'Coding', 'Repairs', 'Tutoring'].map(skill => 
                                        React.createElement('button', {
                                            key: skill,
                                            className: "px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-indigo-100 hover:text-indigo-700 transition-colors"
                                        }, skill)
                                    ))
                                ]),

                                // Buttons
                                React.createElement('div', {
                                    key: 'buttons',
                                    className: "flex gap-3 mt-6"
                                }, [
                                    React.createElement('button', {
                                        key: 'back',
                                        onClick: () => setStep(2),
                                        className: "flex-1 py-4 border-2 border-gray-200 text-gray-700 rounded-xl font-bold hover:bg-gray-50 transition-colors"
                                    }, "Back"),
                                    React.createElement('button', {
                                        key: 'complete',
                                        onClick: () => alert('Account created!'),
                                        className: "flex-1 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-bold shadow-lg hover:shadow-xl transition-all"
                                    }, "Complete")
                                ])
                            ])
                        ]),

                        // Footer
                        React.createElement('p', {
                            key: 'footer',
                            className: "text-center mt-6 text-gray-600"
                        }, [
                            "Already have an account? ",
                            React.createElement('button', {
                                key: 'link',
                                onClick: () => setCurrentScreen('login'),
                                className: "text-indigo-600 font-bold hover:text-indigo-700"
                            }, "Sign in")
                        ])
                    ])
                ]);
            }

            return null;
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(React.createElement(App));
    </script>
</body>
</html>
